# Copy to env/lab/openwrt-dns.tfvars and fill with real values.
environment = "lab"
inventory_root = "../../inventory"
openwrt_hostname = "192.168.100.1"
openwrt_port = 80
openwrt_scheme = "http"
openwrt_username = "root"
openwrt_password = "REPLACE_ME"

openwrt_firewall_enabled = true
openwrt_firewall_apply = true
openwrt_firewall_ssh_host = "192.168.100.1"
openwrt_firewall_ssh_port = 22
openwrt_firewall_ssh_user = "root"
