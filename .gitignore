# -----------------------
# Regras Gerais
# -----------------------

# Logs
*.log
logs/
*.pid

# Caches e temporários
*.tmp
*.swp
*.bak
*.old
*~
.DS_Store
Thumbs.db

# Diretórios temporários comuns
node_modules/
__pycache__/
.cache/
dist/
build/
tmp/

# -----------------------
# Docker / Compose
# -----------------------

.env
.env.local
.envrc
docker-compose.override.yml
.docker/
.volumes/
data/
secrets/

# -----------------------
# SOPS / Encriptação
# -----------------------

# Ficheiros desencriptados / temporários
*.decrypted~
*.unencrypted
*.plain
*.sops.yaml~
*.sops.yml~
*.bak
*.tmp

# Permitir ficheiros encriptados
!*.sops.yaml
!*.sops.yml
!*.sops.env

# Ficheiros auxiliares sensíveis
.agekey
age.txt

# -----------------------
# Terraform
# -----------------------

# Diretório local do Terraform
.terraform/

# Estado (NUNCA versionar)
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.*
crash.log

# Variáveis sensíveis
*.tfvars
*.tfvars.json

# Overrides locais
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config local
.terraformrc
terraform.rc

# -----------------------
# Git / IDEs
# -----------------------

.vscode/
.idea/
*.code-workspace

# Repositórios Git aninhados acidentais
**/.git/

# GitHub workflows (manter)
!/.github/

# -----------------------
# Sistema Operativo
# -----------------------

ehthumbs.db
desktop.ini
Icon?
.Spotlight-V100
.Trashes

# -----------------------
# Certs
# -----------------------
*.pem